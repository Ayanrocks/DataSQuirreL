{
  "identifier": "desktop-capability",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main", "*"],
  "permissions": [
    "global-shortcut:default",
    "fs:default",
    "os:default",
    "process:default",
    "clipboard-manager:default",
    "core:window:default",
    "core:window:allow-start-dragging"
  ]
}
