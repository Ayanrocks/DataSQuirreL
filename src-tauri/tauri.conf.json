{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/tooling/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3001"
  },
  "bundle": {
    "icon": [
      "icons/extension_icon.ico",
      "icons/extension_icon.icns",
      "icons/extension_icon@4096px.png",
      "icons/extension_icon@8192px.png",
      "icons/extension_icon@12288px.png"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DataSquirrel",
        "width": 1450,
        "height": 950,
        "visible": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "url": "http://localhost:3001"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "identifier": "com.banerjeeayan.datasquirrel",
  "plugins": {
    "os": {
      "all": true
    }
  },
  "productName": "DataSquirrel",
  "version": "0.1.3"
}