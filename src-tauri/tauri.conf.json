  {
    "$schema": "../node_modules/@tauri-apps/cli/schema.json",
    "build": {
      "beforeBuildCommand": "npm run build",
      "beforeDevCommand": "npm run dev",
      "frontendDist": "../dist",
      "devUrl": "http://localhost:3001"
    },
    "bundle": {
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "app": {
      "windows": [
        {
          "label": "main",
          "title": "DataSquirrel",
          "width": 900,
          "height": 700,
          "visible": true,
          "resizable": true,
          "fullscreen": false,
          "url": "/index.html"
        }
      ],
      "security": {
        "csp": null
      }
    },
    "identifier": "com.example.myapp",
    "plugins": {},
    "productName": "TauriApp",
    "version": "0.1.2"
  }
